# Copy to `.env` and set real values (never commit `.env`).
#
# GEMINI_API_KEY — Google AI / Gemini API key (PDF extraction).
GEMINI_API_KEY=

# JWT secret key for signing access tokens.
JWT_SECRET=

# Access token expiry in minutes.
JWT_EXPIRES_MINUTES=60

# POST /analyse/copy-ocr and /analyse/copy-ocr-rasterization — max upload (bytes) and max pages.
COPY_OCR_MAX_BYTES=26214400
COPY_OCR_MAX_PAGES=30
# Raster path only: render DPI and max concurrent Gemini calls (default 5).
COPY_OCR_RASTER_DPI=220
COPY_OCR_PARALLEL_WORKERS=5
