# Copy to `.env` and set real values (never commit `.env`).
#
# --- Database -----------------------------------------------------------------
# Required. Postgres connection string. The app rewrites the scheme to
# postgresql+psycopg:// automatically so the bare postgresql:// form works.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional: separate database for pytest fixtures. When unset, DB-backed tests
# are skipped.
# TEST_DATABASE_URL=postgresql://user:password@host:5432/test_dbname?sslmode=require

# GEMINI_API_KEY — Google AI / Gemini API key (PDF extraction).
GEMINI_API_KEY=

# Optional: model for POST /analyse/full, /analyse/cached-ocr, /analyse/combined-review, /analyse/intro-page (e.g. gemini-2.5-flash).
# GEMINI_ANALYSE_MODEL=gemini-2.5-flash

# JWT secret key for signing access tokens.
JWT_SECRET=

# Access token expiry in minutes.
JWT_EXPIRES_MINUTES=60

# POST /analyse/copy-ocr and /analyse/copy-ocr-rasterization — max upload (bytes) and max pages.
COPY_OCR_MAX_BYTES=26214400
COPY_OCR_MAX_PAGES=30
# Raster path only: render DPI and max concurrent Gemini calls (default 5; bump to 8 for higher throughput).
# Raster path only: render DPI and max concurrent Gemini calls (default 5; bump to 8 for higher throughput).
COPY_OCR_RASTER_DPI=220
COPY_OCR_PARALLEL_WORKERS=8

# Optional per-stage Gemini model overrides for /analyse/smart-ocr (default: GEMINI_MODEL).
# SMART_OCR_CLASSIFY_MODEL=gemini-2.5-flash
# SMART_OCR_OCR_MODEL=gemini-2.5-flash
# SMART_OCR_STRUCTURE_MODEL=gemini-2.5-flash

# Smart-OCR latency knobs (every value optional — defaults shown).
# Per-Gemini-call timeouts (milliseconds).
SMART_OCR_CLASSIFY_TIMEOUT_MS=60000
SMART_OCR_OCR_TIMEOUT_MS=60000
SMART_OCR_STRUCTURE_TIMEOUT_MS=60000
# Whole-request deadline (seconds). Pipeline returns HTTP 504 if exceeded.
SMART_OCR_TOTAL_TIMEOUT_S=180
# Structure-stage cap (output tokens). 65536 is the SDK ceiling; 16000 prevents runaway generation.
SMART_OCR_STRUCTURE_MAX_TOKENS=16000
# Structure-stage chunking: split into parallel Gemini calls when page_count > threshold.
SMART_OCR_STRUCTURE_CHUNK_PAGES=5
SMART_OCR_STRUCTURE_CHUNK_THRESHOLD=6
